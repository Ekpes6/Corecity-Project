# ─── CoreCity Properties — Environment Variables ─────────────────────────────
# Copy this file to .env and fill in all values before running docker-compose.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── MySQL ───────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=corecity_db
MYSQL_USER=corecity_user
MYSQL_PASSWORD=change_me_db

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
# Change from the default guest/guest before deploying.
RABBITMQ_USER=corecity_mq
RABBITMQ_PASSWORD=change_me_mq

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 64
# Must be at least 512 bits (64 bytes) for HS512.
JWT_SECRET=REPLACE_WITH_BASE64_64_BYTE_RANDOM_STRING

# ─── BVN / NIN Encryption (AES-256-GCM) ─────────────────────────────────────
# Generate with:  openssl rand -base64 32
# Must decode to exactly 32 bytes (256-bit key).
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_RANDOM_STRING

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_PAYSTACK_SECRET_KEY
# The URL Paystack will redirect to after payment (must be publicly reachable).
PAYSTACK_CALLBACK_URL=https://corecity.com.ng/payment/verify

# ─── File Service ────────────────────────────────────────────────────────────
# Public base URL used to build download links (no trailing slash).
FILE_BASE_URL=https://corecity.com.ng/api/v1/files

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=postmaster@mg.corecity.com.ng
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD

# ─── Termii (SMS) ────────────────────────────────────────────────────────────
TERMII_API_KEY=REPLACE_WITH_TERMII_API_KEY
